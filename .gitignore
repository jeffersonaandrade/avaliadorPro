# See https://help.github.com/articles/ignoring-files/

# ─── Dependências ───
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ───
.next/
out/
build/
dist/

# ─── Variáveis de ambiente (segredos) ───
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
# Mantenha no repo apenas exemplos sem segredos:
!.env.example
!.env*.example

# ─── Vercel / deploy ───
.vercel
.netlify

# ─── Testes & cobertura ───
coverage/
.nyc_output/
*.lcov

# ─── TypeScript ───
*.tsbuildinfo
# next-env.d.ts é gerado pelo Next — costuma versionar no repositório

# ─── Logs & debug ───
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Certificados & chaves ───
*.pem
*.key
*.p12

# ─── Ferramentas / monorepo ───
.turbo
.swc

# ─── Supabase (CLI local, se usar) ───
.branches/
.temp/
supabase/.temp/

# ─── E2E (Playwright / Cypress, se adicionar) ───
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
cypress/videos/
cypress/screenshots/

# ─── IDEs & editores ───
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-*

# VS Code: ignore local; time pode versionar settings.json compartilhado com !exceção
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# ─── Sistema operacional ───
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Misc ───
*.local
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
